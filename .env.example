# Copy to .env.local and fill in. Without these Atlas runs in demo mode
# (sample projects, template proposals, nothing sent to Freelancer).

# Anthropic API key — powers the Scout/Bid/Comms agents
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Freelancer.com OAuth token — freelancer.com > Settings > Developers > generate token
FREELANCER_OAUTH_TOKEN=
# Your numeric Freelancer user id (shown in your profile API / account settings)
FREELANCER_USER_ID=

# Optional: point at the Freelancer sandbox while testing
# FREELANCER_API_BASE=https://www.freelancer-sandbox.com/api

# Optional: override the agent model
# ATLAS_AGENT_MODEL=claude-sonnet-5
